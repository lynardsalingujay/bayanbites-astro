---
import { downloadStrapiImage, type MenuItem } from '../lib/strapi'

interface Props {
  item: MenuItem
}

const { item } = Astro.props
const { name, description, price, isMadeToOrder, image, menu_category } =
  item.attributes

// Download image at build time and get local path
// Handle both single media and multiple media (array)
const imageDataArray = Array.isArray(image?.data)
  ? image?.data
  : image?.data
    ? [image?.data]
    : []

// Sort by caption first, fallback to filename
const sortedImageData = [...imageDataArray].sort((a, b) => {
  const aCaption = a?.attributes?.caption || ''
  const bCaption = b?.attributes?.caption || ''

  if (name === 'Kimchi') {
    console.log(
      `Comparing: ${a?.attributes?.name} (caption: "${aCaption}") vs ${b?.attributes?.name} (caption: "${bCaption}")`,
    )
  }

  const aCaptionNum = parseInt(aCaption)
  const bCaptionNum = parseInt(bCaption)

  if (!isNaN(aCaptionNum) && !isNaN(bCaptionNum)) {
    if (name === 'Kimchi') {
      console.log(
        `  Using caption: ${aCaptionNum} vs ${bCaptionNum} = ${aCaptionNum - bCaptionNum}`,
      )
    }
    return aCaptionNum - bCaptionNum
  }

  const aName = a?.attributes?.name || ''
  const bName = b?.attributes?.name || ''
  const aNum = parseInt(aName.match(/\d+/)?.[0] || '999')
  const bNum = parseInt(bName.match(/\d+/)?.[0] || '999')
  if (name === 'Kimchi') {
    console.log(`  Using filename: ${aNum} vs ${bNum} = ${aNum - bNum}`)
  }
  return aNum - bNum
})

if (name === 'Kimchi') {
  console.log(
    'Final sorted order:',
    sortedImageData.map(
      (img) =>
        `${img?.attributes?.name} (caption: ${img?.attributes?.caption})`,
    ),
  )
  console.log(
    'First image data:',
    sortedImageData[0]?.attributes?.name,
    'URL:',
    sortedImageData[0]?.attributes?.url,
  )
}

const imageData = sortedImageData[0]
const imageUrl = await downloadStrapiImage(imageData?.attributes?.url)

if (name === 'Kimchi') {
  console.log('Downloaded image URL:', imageUrl)
}
const categoryName = menu_category?.data?.attributes?.categoryName

// Generate slug from product name
const slug = name.toLowerCase().replace(/\s+/g, '-')
---

<a
  href={`/products/${slug}`}
  class='group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 h-full flex flex-col border-2 border-gray-200 block'
>
  <div class='relative aspect-[16/11] overflow-hidden bg-gray-100'>
    {
      imageUrl ? (
        <img
          src={imageUrl}
          alt={name}
          class='w-full h-full object-cover group-hover:scale-110 transition-transform duration-500'
        />
      ) : (
        <div class='w-full h-full flex items-center justify-center bg-gradient-to-br from-[#6B4423] to-[#8B5A2B] text-white font-bold text-2xl'>
          <span class='opacity-90'>Bayan Bites</span>
        </div>
      )
    }

    {
      (isMadeToOrder || categoryName) && (
        <div class='absolute top-4 right-4 flex flex-col gap-2 items-end'>
          {isMadeToOrder && (
            <span class='px-3 py-1.5 rounded-full text-xs font-bold bg-white text-[#6B4423] shadow-lg border-2 border-[#6B4423]'>
              Made to Order
            </span>
          )}
          {categoryName && (
            <span class='px-3 py-1.5 rounded-full text-xs font-bold bg-[#FDF6EE] text-[#F5A623] shadow-lg border-2 border-[#F5A623]'>
              {categoryName}
            </span>
          )}
        </div>
      )
    }
  </div>

  <div class='p-6 flex-grow flex flex-col'>
    <div class='flex justify-between items-start gap-4 mb-3'>
      <h3
        class='text-xl font-bold text-[#6B4423] leading-tight m-0 group-hover:text-[#F5A623] transition-colors'
      >
        {name}
      </h3>
      <span class='text-[#F5A623] font-bold text-xl whitespace-nowrap'
        >${price.toFixed(2)}</span
      >
    </div>

    {
      description && (
        <p class='text-[#dc143c] text-sm leading-relaxed m-0 line-clamp-3'>
          {description}
        </p>
      )
    }
  </div>
</a>
