---
import {
  fetchStrapi,
  downloadStrapiImage,
  type MenuItem,
} from '../../lib/strapi'

// Get all menu items to generate static paths
export async function getStaticPaths() {
  const menu = await fetchStrapi<MenuItem>('menu-items')
  
  return menu.data.map((item) => ({
    params: { 
      slug: item.attributes.name.toLowerCase().replace(/\s+/g, '-') 
    },
    props: { item },
  }))
}

const { item } = Astro.props
const { name, description, price, isMadeToOrder, image, menu_category } = item.attributes

// Download all images (handle both single and multiple media)
const imageDataArray = Array.isArray(image?.data) ? image?.data : (image?.data ? [image?.data] : [])

// Sort images by caption (e.g., "1", "2", "3")
// Falls back to filename sorting if no caption
const sortedImageData = [...imageDataArray].sort((a, b) => {
  const aCaption = a?.attributes?.caption || ''
  const bCaption = b?.attributes?.caption || ''
  
  // Try to parse caption as number first
  const aCaptionNum = parseInt(aCaption)
  const bCaptionNum = parseInt(bCaption)
  
  if (!isNaN(aCaptionNum) && !isNaN(bCaptionNum)) {
    return aCaptionNum - bCaptionNum
  }
  
  // Fallback: sort by filename number
  const aName = a?.attributes?.name || ''
  const bName = b?.attributes?.name || ''
  const aNum = parseInt(aName.match(/\d+/)?.[0] || '999')
  const bNum = parseInt(bName.match(/\d+/)?.[0] || '999')
  return aNum - bNum
})

const imageUrls = await Promise.all(
  sortedImageData.map(async (img) => {
    const url = await downloadStrapiImage(img?.attributes?.url)
    return {
      url,
      alt: img?.attributes?.alternativeText || name
    }
  })
)

const categoryName = menu_category?.data?.attributes?.categoryName
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='description' content={description} />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <link rel='icon' type='image/svg+xml' href='/bb_icon2.png' />
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&family=Allura&display=swap'
      rel='stylesheet'
    />
    <title>{name} - BayanBites</title>
  </head>
  <body class="font-['Quicksand'] bg-[#f5f1ed]">
    <!-- Top Announcement Banner -->
    <div class='bg-[#ab2a08] text-[#FFFFFF] py-3 text-center'>
      <p class='text-sm md:text-base px-4'>
        Authentic Flavors Made with Love
      </p>
    </div>

    <!-- Navigation -->
    <nav class='bg-[#F6F1ED] sticky top-0 z-50 pt-2'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2'>
        <div class='flex flex-col items-center space-y-4'>
          <!-- Logo -->
          <div class='flex items-center justify-center'>
            <a href='/' aria-label='BayanBites Home'>
              <img
                src='/logo.png'
                alt='BayanBites Logo'
                class='h-16 md:h-20 lg:h-24 w-auto cursor-pointer hover:opacity-90 transition-opacity'
              />
            </a>
          </div>

          <!-- Navigation Links -->
          <div class='flex items-center space-x-6'>
            <a
              href='/'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Home</a
            >
            <div class='relative group'>
              <button
                class='text-[#ab2a08] hover:text-[#F5A623] transition-colors flex items-center gap-1'
              >
                Menu
                <svg
                  class='w-4 h-4 transition-transform group-hover:rotate-180'
                  fill='none'
                  stroke='currentColor'
                  viewBox='0 0 24 24'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M19 9l-7 7-7-7'></path>
                </svg>
              </button>
              <div
                class='absolute left-0 mt-2 w-48 bg-white shadow-lg rounded-md opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50'
              >
                <a
                  href='/cookies'
                  class='block px-4 py-3 text-[#ab2a08] hover:bg-[#f5f1ed] hover:text-[#F5A623] transition-colors'
                  >Cookies</a
                >
                <a
                  href='/cinnamon'
                  class='block px-4 py-3 text-[#ab2a08] hover:bg-[#f5f1ed] hover:text-[#F5A623] transition-colors'
                  >Cinnamon Rolls</a
                >
                <a
                  href='/cakes'
                  class='block px-4 py-3 text-[#ab2a08] hover:text-[#F5A623] transition-colors'
                  >Cakes</a
                >
                <a
                  href='/asian-bites'
                  class='block px-4 py-3 text-[#ab2a08] hover:bg-[#f5f1ed] hover:text-[#F5A623] transition-colors'
                  >Asian Bites</a
                >
              </div>
            </div>
            <a
              href='/#our-story'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Our Story</a
            >
            <a
              href='/contact.html'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Contact</a
            >
          </div>
        </div>
      </div>
    </nav>

    <!-- Product Detail Section -->
    <main class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12'>
      <!-- Breadcrumb -->
      <div class='mb-8'>
        <a href='/' class='text-[#ab2a08] hover:text-[#F5A623]'>Home</a>
        <span class='mx-2 text-[#dc143c]'>/</span>
        {categoryName && (
          <>
            <a href={`/${categoryName.toLowerCase().replace(/\s+/g, '-')}`} class='text-[#ab2a08] hover:text-[#F5A623]'>
              {categoryName}
            </a>
            <span class='mx-2 text-[#dc143c]'>/</span>
          </>
        )}
        <span class='text-[#dc143c]'>{name}</span>
      </div>

      <div class='grid grid-cols-1 lg:grid-cols-2 gap-12'>
        <!-- Image Gallery -->
        <div>
          {imageUrls.length > 0 ? (
            <div class='space-y-4'>
              <!-- Main Image -->
              <div class='aspect-square bg-gray-100 rounded-lg overflow-hidden'>
                <img
                  id='main-image'
                  src={imageUrls[0].url}
                  alt={imageUrls[0].alt}
                  class='w-full h-full object-cover'
                />
              </div>
              
              <!-- Thumbnail Gallery -->
              {imageUrls.length > 1 && (
                <div class='grid grid-cols-4 gap-4'>
                  {imageUrls.map((img, index) => (
                    <button
                      class='aspect-square bg-gray-100 rounded-lg overflow-hidden border-2 border-transparent hover:border-[#F5A623] transition-colors thumbnail-btn'
                      data-index={index}
                    >
                      <img
                        src={img.url}
                        alt={img.alt}
                        class='w-full h-full object-cover'
                      />
                    </button>
                  ))}
                </div>
              )}
            </div>
          ) : (
            <div class='aspect-square bg-gradient-to-br from-[#6B4423] to-[#8B5A2B] rounded-lg flex items-center justify-center'>
              <span class='text-white text-3xl font-bold opacity-90'>Bayan Bites</span>
            </div>
          )}
        </div>

        <!-- Product Info -->
        <div>
          {categoryName && (
            <span class='inline-block px-4 py-2 rounded-full text-sm font-bold bg-[#FDF6EE] text-[#F5A623] border-2 border-[#F5A623] mb-4'>
              {categoryName}
            </span>
          )}
          
          <h1 class='text-4xl md:text-5xl font-bold text-[#ab2a08] mb-4'>
            {name}
          </h1>
          
          <div class='text-3xl font-bold text-[#F5A623] mb-6'>
            ${price.toFixed(2)}
          </div>

          {isMadeToOrder && (
            <div class='bg-white border-2 border-[#6B4423] rounded-lg p-4 mb-6'>
              <div class='flex items-center gap-2'>
                <svg class='w-5 h-5 text-[#6B4423]' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                  <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'></path>
                </svg>
                <span class='font-semibold text-[#6B4423]'>Made to Order</span>
              </div>
              <p class='text-sm text-[#dc143c] mt-2'>
                This item is freshly prepared when you order. Please allow 24-48 hours for preparation.
              </p>
            </div>
          )}

          <div class='prose prose-lg mb-8'>
            <h2 class='text-2xl font-semibold text-[#ab2a08] mb-4'>Description</h2>
            <p class='text-[#dc143c] leading-relaxed'>
              {description}
            </p>
          </div>

          <!-- Call to Action -->
          <div class='space-y-4'>
            <a
              href='/contact.html'
              class='block w-full bg-[#ab2a08] text-white text-center px-8 py-4 rounded-lg hover:bg-[#8B0000] transition-colors text-lg font-semibold'
            >
              Order Now
            </a>
            <a
              href={categoryName ? `/${categoryName.toLowerCase().replace(/\s+/g, '-')}` : '/'}
              class='block w-full border-2 border-[#ab2a08] text-[#ab2a08] text-center px-8 py-4 rounded-lg hover:bg-[#f5f1ed] transition-colors'
            >
              Back to {categoryName || 'Menu'}
            </a>
          </div>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class='bg-[#ab2a08] text-white py-12 mt-20'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='grid grid-cols-1 md:grid-cols-2 gap-8'>
          <div>
            <h3 class='text-2xl mb-4'>BayanBites</h3>
            <p class='text-[#f5f1ed]'>
              Where every bite brings us together
            </p>
          </div>
          <div>
            <h4 class='text-xl mb-4'>Contact Us</h4>
            <p class='text-[#f5f1ed] mb-2'>Phone: 020 4054 8889</p>
            <a
              href='https://www.facebook.com/profile.php?id=61581222617160'
              target='_blank'
              rel='noopener noreferrer'
              class='text-[#f5f1ed] hover:text-[#F5A623] transition-colors inline-flex items-center gap-2'
            >
              <svg class='w-5 h-5' fill='currentColor' viewBox='0 0 24 24'>
                <path
                  d='M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z'
                ></path>
              </svg>
              Visit us on Facebook
            </a>
          </div>
        </div>
        <div class='mt-8 pt-8 border-t border-[#dc143c] text-center'>
          <p class='text-[#f5f1ed]'>
            &copy; 2026 BayanBites. All rights reserved.
          </p>
        </div>
      </div>
    </footer>

    <script>
      // Image gallery functionality
      const mainImage = document.getElementById('main-image') as HTMLImageElement
      const thumbnails = document.querySelectorAll('.thumbnail-btn')
      const imageData = {imageUrls: JSON.stringify(imageUrls)}

      thumbnails.forEach((btn) => {
        btn.addEventListener('click', () => {
          const index = parseInt(btn.getAttribute('data-index') || '0')
          const images = JSON.parse('{imageData.imageUrls}')
          if (images[index]) {
            mainImage.src = images[index].url
            mainImage.alt = images[index].alt
          }
        })
      })
    </script>

    <script define:vars={{ imageUrls }}>
      // Image gallery with proper data
      const mainImage = document.getElementById('main-image')
      const thumbnails = document.querySelectorAll('.thumbnail-btn')

      thumbnails.forEach((btn) => {
        btn.addEventListener('click', () => {
          const index = parseInt(btn.getAttribute('data-index') || '0')
          if (imageUrls[index] && mainImage) {
            mainImage.src = imageUrls[index].url
            mainImage.alt = imageUrls[index].alt
          }
        })
      })
    </script>
  </body>
</html>
