---
// Cookies page - temporary product page
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='description' content='Freshly baked cookies from BayanBites' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&display=swap'
      rel='stylesheet'
    />
    <title>Cookies - BayanBites</title>
  </head>
  <body class="font-['Playfair_Display'] bg-[#f5f1ed]">
    <!-- Top Announcement Banner -->
    <div class='bg-[#ab2a08] text-[#FFFFFF] py-3 text-center'>
      <p class='text-sm md:text-base px-4'>
        Freshly Baked Cookies Made with Love
      </p>
    </div>

    <!-- Navigation -->
    <nav class='bg-[#F6F1ED] sticky top-0 z-50 pt-2'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2'>
        <div class='flex flex-col items-center space-y-4'>
          <!-- Logo -->
          <div class='flex items-center justify-center'>
            <a href='/' aria-label='BayanBites Home'>
              <img
                src='/logo.png'
                alt='BayanBites Logo'
                class='h-16 md:h-20 lg:h-24 w-auto cursor-pointer hover:opacity-90 transition-opacity'
              />
            </a>
          </div>

          <!-- Navigation Links -->
          <div class='flex items-center space-x-6'>
            <a
              href='/'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Home</a
            >
            <a
              href='/cookies'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors font-semibold'
              >Cookies</a
            >
            <a
              href='/cinnamon'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Cinnamon Rolls</a
            >
            <a
              href='/cakes'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Cakes</a
            >
            <a
              href='/#our-story'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Our Story</a
            >
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class='bg-white py-20'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center'>
        <h1 class='text-5xl md:text-6xl text-[#ab2a08] mb-6'>
          Freshly Baked Cookies
        </h1>
        <p class='text-xl text-[#8B7355] max-w-3xl mx-auto mb-8'>
          Thick, gooey, chunky cookies made from scratch with premium
          ingredients. Each batch is baked fresh to order, bringing you the
          perfect combination of crispy edges and soft, chewy centers.
        </p>
      </div>
    </section>

    <!-- Content Section -->
    <section class='py-20 bg-[#f5f1ed]'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='grid grid-cols-1 md:grid-cols-2 gap-12 mb-16'>
          <div>
            <h2 class='text-3xl text-[#ab2a08] mb-6'>
              What Makes Our Cookies Special
            </h2>
            <div class='space-y-4 text-[#8B7355]'>
              <p class='flex items-start'>
                <span class='text-2xl mr-3'>🍪</span>
                <span
                  ><strong>Made to Order:</strong> Every batch is baked fresh for
                  you, ensuring maximum flavor and perfect texture.</span
                >
              </p>
              <p class='flex items-start'>
                <span class='text-2xl mr-3'>🥛</span>
                <span
                  ><strong>Premium Ingredients:</strong> We use high-quality chocolate,
                  real butter, and the finest ingredients available.</span
                >
              </p>
              <p class='flex items-start'>
                <span class='text-2xl mr-3'>❤️</span>
                <span
                  ><strong>Handcrafted with Love:</strong> Each cookie is portioned
                  by hand and baked with care in small batches.</span
                >
              </p>
              <p class='flex items-start'>
                <span class='text-2xl mr-3'>🌟</span>
                <span
                  ><strong>Unique Recipes:</strong> Our recipes are developed in-house,
                  inspired by classic flavors with a personal twist.</span
                >
              </p>
            </div>
          </div>

          <div class='bg-white p-8 rounded-lg shadow-md'>
            <h3 class='text-2xl text-[#ab2a08] mb-6'>Cookie Varieties</h3>
            <ul class='space-y-3 text-[#8B7355]'>
              <li class='flex items-center'>
                <span class='text-[#ab2a08] mr-2'>✓</span>
                Classic Chocolate Chip
              </li>
              <li class='flex items-center'>
                <span class='text-[#ab2a08] mr-2'>✓</span>
                Double Chocolate Chunk
              </li>
              <li class='flex items-center'>
                <span class='text-[#ab2a08] mr-2'>✓</span>
                Oatmeal Raisin
              </li>
              <li class='flex items-center'>
                <span class='text-[#ab2a08] mr-2'>✓</span>
                Peanut Butter
              </li>
              <li class='flex items-center'>
                <span class='text-[#ab2a08] mr-2'>✓</span>
                White Chocolate Macadamia
              </li>
              <li class='flex items-center'>
                <span class='text-[#ab2a08] mr-2'>✓</span>
                Seasonal Specials
              </li>
            </ul>
            <div class='mt-8 pt-6 border-t border-[#f5f1ed]'>
              <p class='text-sm text-[#8B7355] italic'>
                Check our menu for current availability and pricing
              </p>
            </div>
          </div>
        </div>

        <!-- Call to Action -->
        <div class='text-center bg-white p-12 rounded-lg shadow-md'>
          <h3 class='text-3xl text-[#ab2a08] mb-4'>Ready to Order?</h3>
          <p class='text-lg text-[#8B7355] mb-8 max-w-2xl mx-auto'>
            Our cookies are baked fresh to order. Perfect for gifts,
            celebrations, or simply treating yourself to something special.
          </p>
          <a
            href='/'
            class='inline-block bg-[#ab2a08] text-white px-8 py-3 rounded-md hover:bg-[#8B0000] transition-colors text-lg'
          >
            View Menu & Order
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class='bg-[#ab2a08] text-white py-12'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center'>
        <h3 class='text-2xl mb-4'>BayanBites</h3>
        <p class='text-[#f5f1ed] mb-6'>
          Freshly baked goods made with quality ingredients and thoughtful care.
        </p>
        <div class='border-t border-[#8B7355] pt-6 mt-6'>
          <p class='text-[#f5f1ed]'>
            &copy; 2026 BayanBites. All rights reserved.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
