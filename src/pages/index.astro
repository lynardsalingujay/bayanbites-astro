---
import {
  fetchStrapi,
  fetchStrapiSingle,
  type MenuItem,
  type StrapiResponse,
} from '../lib/strapi'
import SimpleMenuCard from '../components/SimpleMenuCard.astro'
import Hero from '../components/Hero.astro'

// ⚡ BUILD-TIME DATA FETCHING
// All Strapi API calls execute during build (astro build), NOT at runtime.
// If Strapi is unavailable, the build will fail loudly with clear error messages.
// The final output is pure static HTML with embedded content.

const menu = await fetchStrapi<MenuItem>('menu-items')
const homepage = await fetchStrapiSingle('homepage')
const heroSection = homepage?.data?.attributes?.heroSection
const heroData = Array.isArray(heroSection) ? heroSection[0] : heroSection
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='description' content='Authentic Filipino home-cooked meals' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <meta name='generator' content={Astro.generator} />
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&display=swap'
      rel='stylesheet'
    />
    <title>BayanBites - Authentic Filipino Home-Cooked Meals</title>
  </head>
  <body class="font-['Playfair_Display'] bg-[#f5f1ed]">
    <!-- Top Announcement Banner -->
    <div class='bg-[#ab2a08] text-[#FFFFFF] py-3 text-center'>
      <p class='text-sm md:text-base px-4'>
        Authentic Filipino Home-Cooked Meals, Made with Love
      </p>
    </div>

    <!-- Mobile Menu Overlay -->
    <div
      id='mobile-overlay'
      class='fixed inset-0 bg-black bg-opacity-50 z-40 hidden'
    >
    </div>

    <!-- Mobile Sidebar Menu -->
    <div
      id='mobile-menu'
      class='fixed left-0 w-64 bg-white shadow-xl z-50 transform -translate-x-full transition-transform duration-300 ease-in-out'
      style='top: var(--nav-height, 0px); height: calc(100vh - var(--nav-height, 0px));'
    >
      <div class='flex flex-col h-full'>
        <!-- Mobile Navigation Links -->
        <nav class='flex flex-col space-y-6 px-8 pt-20 pb-8'>
          <a
            href='/'
            class='text-[#ab2a08] hover:text-[#F5A623] text-lg transition-colors mobile-menu-link'
            >Home</a
          >
          <!-- Shop with Submenu (Mobile) -->
          <div>
            <button
              class='mobile-shop-toggle text-[#ab2a08] hover:text-[#F5A623] text-lg transition-colors flex items-center justify-between w-full'
            >
              <span>Shop</span>
              <svg
                class='w-4 h-4 mobile-shop-arrow transition-transform'
                fill='none'
                stroke='currentColor'
                viewBox='0 0 24 24'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M19 9l-7 7-7-7'></path>
              </svg>
            </button>
            <div class='mobile-shop-submenu hidden pl-4 mt-3 space-y-3'>
              <a
                href='/cookies'
                class='text-[#ab2a08] hover:text-[#F5A623] transition-colors block mobile-menu-link'
                >Cookies</a
              >
              <a
                href='/cinnamon'
                class='text-[#ab2a08] hover:text-[#F5A623] transition-colors block mobile-menu-link'
                >Cinnamon Rolls</a
              >
              <a
                href='/cakes'
                class='text-[#ab2a08] hover:text-[#F5A623] transition-colors block mobile-menu-link'
                >Cakes</a
              >
            </div>
          </div>
          <a
            href='#our-story'
            class='text-[#ab2a08] hover:text-[#F5A623] text-lg transition-colors mobile-menu-link smooth-scroll'
            >Our Story</a
          >
          <a
            href='/contact.html'
            class='text-[#ab2a08] hover:text-[#F5A623] text-lg transition-colors mobile-menu-link'
            >Contact</a
          >
        </nav>
      </div>
    </div>

    <!-- Navigation -->
    <nav
      id='main-nav'
      class='bg-[#F6F1ED] sticky top-0 z-50 transition-transform duration-300 pt-2'
    >
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2'>
        <div class='flex justify-between items-center md:flex-col'>
          <!-- Hamburger/Close Button (Mobile Only) -->
          <button
            id='hamburger-btn'
            class='md:hidden text-[#ab2a08] hover:text-[#F5A623] transition-colors'
            aria-label='Toggle menu'
          >
            <!-- Hamburger Icon -->
            <svg
              id='hamburger-icon'
              class='w-6 h-6'
              fill='none'
              stroke='currentColor'
              viewBox='0 0 24 24'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M4 6h16M4 12h16M4 18h16'></path>
            </svg>
            <!-- Close Icon (Hidden by default) -->
            <svg
              id='close-icon'
              class='w-6 h-6 hidden'
              fill='none'
              stroke='currentColor'
              viewBox='0 0 24 24'
            >
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                stroke-width='2'
                d='M6 18L18 6M6 6l12 12'></path>
            </svg>
          </button>

          <!-- Logo -->
          <div class='flex items-center justify-center'>
            <a href='/' aria-label='BayanBites Home'>
              <img
                src='/logo.png'
                alt='BayanBites Logo'
                class='h-20 md:h-24 lg:h-28 w-auto cursor-pointer hover:opacity-90 transition-opacity'
              />
            </a>
          </div>

          <!-- Desktop Navigation Links (Hidden on Mobile) -->
          <div class='hidden md:flex items-center space-x-8'>
            <a
              href='/'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Home</a
            >
            <!-- Shop Dropdown (Desktop) -->
            <div class='relative shop-dropdown group'>
              <button
                class='text-[#ab2a08] hover:text-[#F5A623] transition-colors flex items-center gap-1'
              >
                Shop
                <svg
                  class='w-4 h-4 transition-transform group-hover:rotate-180'
                  fill='none'
                  stroke='currentColor'
                  viewBox='0 0 24 24'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M19 9l-7 7-7-7'></path>
                </svg>
              </button>
              <div
                class='absolute left-0 mt-2 w-48 bg-white shadow-lg rounded-md opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50'
              >
                <a
                  href='/cookies'
                  class='block px-4 py-3 text-[#ab2a08] hover:bg-[#f5f1ed] hover:text-[#F5A623] transition-colors'
                  >Cookies</a
                >
                <a
                  href='/cinnamon'
                  class='block px-4 py-3 text-[#ab2a08] hover:bg-[#f5f1ed] hover:text-[#F5A623] transition-colors'
                  >Cinnamon Rolls</a
                >
                <a
                  href='/cakes'
                  class='block px-4 py-3 text-[#ab2a08] hover:bg-[#f5f1ed] hover:text-[#F5A623] transition-colors'
                  >Cakes</a
                >
              </div>
            </div>
            <a
              href='#our-story'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors smooth-scroll'
              >Our Story</a
            >
            <a
              href='/contact.html'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Contact</a
            >
          </div>

          <!-- Spacer for mobile to center logo -->
          <div class='md:hidden w-6'></div>
        </div>
      </div>
    </nav>

    <!-- Hero Section -->
    <Hero heroData={heroData} />

    <!-- Why Choose Us Section -->
    <section class='py-20 bg-white'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
        <h2 class='text-4xl text-center mb-12 text-[#ab2a08]'>
          Why Choose BayanBites?
        </h2>
        <div class='grid grid-cols-1 md:grid-cols-3 gap-8'>
          <div class='text-center p-6'>
            <div class='text-5xl mb-4'>🏠</div>
            <h3 class='text-xl mb-2 text-[#ab2a08]'>Home-Cooked Goodness</h3>
            <p class='text-[#8B7355]'>
              Every dish is prepared with love, just like home.
            </p>
          </div>
          <div class='text-center p-6'>
            <div class='text-5xl mb-4'>🌾</div>
            <h3 class='text-xl mb-2 text-[#ab2a08]'>Fresh Ingredients</h3>
            <p class='text-[#8B7355]'>
              We use only the freshest, locally-sourced ingredients.
            </p>
          </div>
          <div class='text-center p-6'>
            <div class='text-5xl mb-4'>❤️</div>
            <h3 class='text-xl mb-2 text-[#ab2a08]'>Made with Love</h3>
            <p class='text-[#8B7355]'>
              Recipes passed down through generations.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Menu Section -->
    <section id='menu' class='py-20 bg-[#f5f1ed]'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
        <h2 class='text-4xl text-center mb-4 text-[#ab2a08]'>Our Menu</h2>
        <p class='text-center text-[#8B7355] mb-12 text-lg'>
          Discover our delicious selection of Filipino favorites
        </p>

        <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8'>
          {menu?.data?.map((item) => <SimpleMenuCard item={item} />)}
        </div>

        {
          !menu?.data?.length && (
            <p class='text-center text-[#8B7355]'>
              No menu items available at the moment.
            </p>
          )
        }
      </div>
    </section>

    <!-- Our Story Section -->
    <section id='our-story' class='py-20 bg-white'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
        <h2 class='text-4xl text-center mb-8 text-[#ab2a08]'>Our Story</h2>
        <div class='max-w-3xl mx-auto text-center'>
          <p class='text-lg text-[#8B7355] mb-6'>
            Bayan Bites began with a love of home baking and the joy of sharing
            food with others. "Bayan" means community, while "Bites" represents
            the small, meaningful moments we share around food—the little joys
            that connect us, one bite at a time.
          </p>
          <p class='text-lg text-[#8B7355] mb-6'>
            Our kitchen offers freshly baked cookies, cakes, sweet pastries, and
            home-style Asian meals, all made with quality ingredients and
            thoughtful care. Each dish starts with curiosity—I create my own
            recipes and adapt others inspired by the cultures I love,
            personalising each one to share what brings me joy.
          </p>
          <p class='text-lg text-[#8B7355] mb-6'>
            As a self-taught baker, connecting with others through food is what
            Bayan Bites is all about. We believe good food brings people
            together, whether for a celebration or a quiet moment after a long
            day.
          </p>
          <p class='text-lg text-[#8B7355]'>
            We're grateful to be part of the Christchurch community and
            delighted to share our table with you.
          </p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class='bg-[#ab2a08] text-white py-12'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='grid grid-cols-1 md:grid-cols-3 gap-8'>
          <div>
            <h3 class='text-2xl mb-4'>BayanBites</h3>
            <p class='text-[#f5f1ed]'>
              Bringing authentic Filipino flavors to your table.
            </p>
          </div>
          <div>
            <h4 class='text-xl mb-4'>Quick Links</h4>
            <ul class='space-y-2'>
              <li>
                <a
                  href='#home'
                  class='text-[#f5f1ed] hover:text-[#F5A623] transition-colors'
                  >Home</a
                >
              </li>
              <li>
                <a
                  href='#menu'
                  class='text-[#f5f1ed] hover:text-[#F5A623] transition-colors'
                  >Menu</a
                >
              </li>
              <li>
                <a
                  href='#about'
                  class='text-[#f5f1ed] hover:text-[#F5A623] transition-colors'
                  >About</a
                >
              </li>
              <li>
                <a
                  href='#contact'
                  class='text-[#f5f1ed] hover:text-[#F5A623] transition-colors'
                  >Contact</a
                >
              </li>
            </ul>
          </div>
          <div>
            <h4 class='text-xl mb-4'>Contact Us</h4>
            <p class='text-[#f5f1ed] mb-2'>Email: info@bayanbites.com</p>
            <p class='text-[#f5f1ed]'>Phone: (123) 456-7890</p>
          </div>
        </div>
        <div class='mt-8 pt-8 border-t border-[#8B7355] text-center'>
          <p class='text-[#f5f1ed]'>
            &copy; 2026 BayanBites. All rights reserved.
          </p>
        </div>
      </div>
    </footer>

    <script>
      // Set navbar height for mobile menu positioning
      function updateNavHeight() {
        const nav = document.getElementById('main-nav')
        if (nav) {
          const navHeight = nav.offsetHeight
          document.documentElement.style.setProperty(
            '--nav-height',
            `${navHeight}px`,
          )
        }
      }

      // Update on load and resize
      updateNavHeight()
      window.addEventListener('resize', updateNavHeight)

      // Mobile menu toggle functionality
      const hamburgerBtn = document.getElementById('hamburger-btn')
      const hamburgerIcon = document.getElementById('hamburger-icon')
      const closeIcon = document.getElementById('close-icon')
      const mobileMenu = document.getElementById('mobile-menu')
      const mobileOverlay = document.getElementById('mobile-overlay')
      const mobileMenuLinks = document.querySelectorAll('.mobile-menu-link')

      function openMenu() {
        mobileMenu.classList.remove('-translate-x-full')
        mobileOverlay.classList.remove('hidden')
        hamburgerIcon.classList.add('hidden')
        closeIcon.classList.remove('hidden')
        document.body.style.overflow = 'hidden'
      }

      function closeMenu() {
        mobileMenu.classList.add('-translate-x-full')
        mobileOverlay.classList.add('hidden')
        hamburgerIcon.classList.remove('hidden')
        closeIcon.classList.add('hidden')
        document.body.style.overflow = ''
      }

      hamburgerBtn?.addEventListener('click', () => {
        if (mobileMenu.classList.contains('-translate-x-full')) {
          openMenu()
        } else {
          closeMenu()
        }
      })

      // Close menu when clicking on overlay
      mobileOverlay?.addEventListener('click', closeMenu)

      // Close menu when clicking on a link
      mobileMenuLinks.forEach((link) => {
        link.addEventListener('click', closeMenu)
      })

      // Mobile Shop Submenu Toggle
      const mobileShopToggle = document.querySelector('.mobile-shop-toggle')
      const mobileShopSubmenu = document.querySelector('.mobile-shop-submenu')
      const mobileShopArrow = document.querySelector('.mobile-shop-arrow')

      mobileShopToggle?.addEventListener('click', () => {
        if (mobileShopSubmenu.classList.contains('hidden')) {
          mobileShopSubmenu.classList.remove('hidden')
          mobileShopArrow.style.transform = 'rotate(180deg)'
        } else {
          mobileShopSubmenu.classList.add('hidden')
          mobileShopArrow.style.transform = 'rotate(0deg)'
        }
      })

      // Smooth Scrolling for anchor links
      document.querySelectorAll('.smooth-scroll').forEach((anchor) => {
        anchor.addEventListener('click', function (e) {
          const href = this.getAttribute('href')
          if (href && href.startsWith('#')) {
            e.preventDefault()
            const targetId = href.substring(1)
            const targetElement = document.getElementById(targetId)
            if (targetElement) {
              targetElement.scrollIntoView({
                behavior: 'smooth',
                block: 'start',
              })
              // Close mobile menu if open
              closeMenu()
            }
          }
        })
      })

      // Hide navigation on scroll down, show on scroll up
      let lastScrollTop = 0
      const nav = document.getElementById('main-nav')
      const scrollThreshold = 100 // Start hiding after scrolling 100px

      window.addEventListener('scroll', () => {
        const scrollTop =
          window.pageYOffset || document.documentElement.scrollTop

        // Only apply hide/show behavior after scrolling past threshold
        if (scrollTop > scrollThreshold) {
          if (scrollTop > lastScrollTop) {
            // Scrolling down - hide nav
            nav.style.transform = 'translateY(-100%)'
          } else {
            // Scrolling up - show nav
            nav.style.transform = 'translateY(0)'
          }
        } else {
          // At top of page - always show nav
          nav.style.transform = 'translateY(0)'
        }

        lastScrollTop = scrollTop
      })
    </script>
  </body>
</html>
