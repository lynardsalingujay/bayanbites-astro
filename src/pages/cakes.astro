---
// Cakes page - temporary product page
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='description' content='Custom cakes from BayanBites' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&display=swap'
      rel='stylesheet'
    />
    <title>Cakes - BayanBites</title>
  </head>
  <body class="font-['Playfair_Display'] bg-[#f5f1ed]">
    <!-- Top Announcement Banner -->
    <div class='bg-[#ab2a08] text-[#FFFFFF] py-3 text-center'>
      <p class='text-sm md:text-base px-4'>
        Beautiful Cakes for Every Celebration
      </p>
    </div>

    <!-- Navigation -->
    <nav class='bg-[#F6F1ED] sticky top-0 z-50 pt-2'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2'>
        <div class='flex flex-col items-center space-y-4'>
          <!-- Logo -->
          <div class='flex items-center justify-center'>
            <a href='/' aria-label='BayanBites Home'>
              <img
                src='/logo.png'
                alt='BayanBites Logo'
                class='h-16 md:h-20 lg:h-24 w-auto cursor-pointer hover:opacity-90 transition-opacity'
              />
            </a>
          </div>

          <!-- Navigation Links -->
          <div class='flex items-center space-x-6'>
            <a
              href='/'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Home</a
            >
            <a
              href='/cookies'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Cookies</a
            >
            <a
              href='/cinnamon'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Cinnamon Rolls</a
            >
            <a
              href='/cakes'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors font-semibold'
              >Cakes</a
            >
            <a
              href='/#our-story'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Our Story</a
            >
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class='bg-white py-20'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center'>
        <h1 class='text-5xl md:text-6xl text-[#ab2a08] mb-6'>Custom Cakes</h1>
        <p class='text-xl text-[#8B7355] max-w-3xl mx-auto mb-8'>
          Handcrafted cakes baked from scratch for your special occasions. From
          birthdays to celebrations, each cake is made with premium ingredients
          and designed with care.
        </p>
      </div>
    </section>

    <!-- Content Section -->
    <section class='py-20 bg-[#f5f1ed]'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='grid grid-cols-1 md:grid-cols-2 gap-12 mb-16'>
          <div>
            <h2 class='text-3xl text-[#ab2a08] mb-6'>Cake Occasions</h2>
            <div class='space-y-4 text-[#8B7355]'>
              <p class='flex items-start'>
                <span class='text-2xl mr-3'>🎂</span>
                <span
                  ><strong>Birthdays:</strong> Classic or custom designs to match
                  any theme or age.</span
                >
              </p>
              <p class='flex items-start'>
                <span class='text-2xl mr-3'>💍</span>
                <span
                  ><strong>Celebrations:</strong> Perfect for engagements, anniversaries,
                  and special milestones.</span
                >
              </p>
              <p class='flex items-start'>
                <span class='text-2xl mr-3'>🎉</span>
                <span
                  ><strong>Events:</strong> Beautiful centerpiece cakes for parties
                  and gatherings.</span
                >
              </p>
              <p class='flex items-start'>
                <span class='text-2xl mr-3'>🎁</span>
                <span
                  ><strong>Just Because:</strong> Treat yourself or someone special
                  to a delicious homemade cake.</span
                >
              </p>
            </div>
          </div>

          <div class='bg-white p-8 rounded-lg shadow-md'>
            <h3 class='text-2xl text-[#ab2a08] mb-6'>Popular Flavors</h3>
            <ul class='space-y-3 text-[#8B7355]'>
              <li class='flex items-center'>
                <span class='text-[#ab2a08] mr-2'>✓</span>
                Classic Vanilla
              </li>
              <li class='flex items-center'>
                <span class='text-[#ab2a08] mr-2'>✓</span>
                Rich Chocolate
              </li>
              <li class='flex items-center'>
                <span class='text-[#ab2a08] mr-2'>✓</span>
                Red Velvet
              </li>
              <li class='flex items-center'>
                <span class='text-[#ab2a08] mr-2'>✓</span>
                Lemon
              </li>
              <li class='flex items-center'>
                <span class='text-[#ab2a08] mr-2'>✓</span>
                Carrot Cake
              </li>
              <li class='flex items-center'>
                <span class='text-[#ab2a08] mr-2'>✓</span>
                Custom Flavors Available
              </li>
            </ul>
            <div class='mt-8 pt-6 border-t border-[#f5f1ed]'>
              <p class='text-sm text-[#8B7355] italic'>
                All cakes can be customized with your choice of frosting,
                fillings, and decorations
              </p>
            </div>
          </div>
        </div>

        <!-- Ordering Information -->
        <div class='bg-white p-12 rounded-lg shadow-md mb-12'>
          <h3 class='text-3xl text-[#ab2a08] mb-6 text-center'>How to Order</h3>
          <div class='grid grid-cols-1 md:grid-cols-3 gap-8 text-center'>
            <div>
              <div class='text-4xl mb-4'>1️⃣</div>
              <h4 class='text-xl text-[#ab2a08] mb-2'>Contact Us</h4>
              <p class='text-[#8B7355]'>
                Reach out with your cake requirements and occasion details
              </p>
            </div>
            <div>
              <div class='text-4xl mb-4'>2️⃣</div>
              <h4 class='text-xl text-[#ab2a08] mb-2'>Customize</h4>
              <p class='text-[#8B7355]'>
                Choose your flavor, size, design, and any special requests
              </p>
            </div>
            <div>
              <div class='text-4xl mb-4'>3️⃣</div>
              <h4 class='text-xl text-[#ab2a08] mb-2'>Enjoy</h4>
              <p class='text-[#8B7355]'>
                Pick up your freshly baked cake on your scheduled date
              </p>
            </div>
          </div>
          <div class='mt-8 text-center'>
            <p class='text-[#8B7355] mb-4'>
              <strong>Note:</strong> Please order at least 3-5 days in advance for
              custom cakes
            </p>
          </div>
        </div>

        <!-- Call to Action -->
        <div class='text-center bg-white p-12 rounded-lg shadow-md'>
          <h3 class='text-3xl text-[#ab2a08] mb-4'>
            Ready to Order Your Cake?
          </h3>
          <p class='text-lg text-[#8B7355] mb-8 max-w-2xl mx-auto'>
            Contact us to discuss your cake needs. We'll work with you to create
            the perfect cake for your celebration.
          </p>
          <a
            href='/'
            class='inline-block bg-[#ab2a08] text-white px-8 py-3 rounded-md hover:bg-[#8B0000] transition-colors text-lg'
          >
            Get in Touch
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class='bg-[#ab2a08] text-white py-12'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center'>
        <h3 class='text-2xl mb-4'>BayanBites</h3>
        <p class='text-[#f5f1ed] mb-6'>
          Freshly baked goods made with quality ingredients and thoughtful care.
        </p>
        <div class='border-t border-[#8B7355] pt-6 mt-6'>
          <p class='text-[#f5f1ed]'>
            &copy; 2026 BayanBites. All rights reserved.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
