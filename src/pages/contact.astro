---
// Contact page - Get in touch with BayanBites
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta
      name='description'
      content='Contact BayanBites - Order our delicious Filipino baked goods'
    />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&display=swap'
      rel='stylesheet'
    />
    <title>Contact Us - BayanBites</title>
  </head>
  <body class="font-['Quicksand'] bg-[#f5f1ed]">
    <!-- Top Announcement Banner -->
    <div class='bg-[#ab2a08] text-[#FFFFFF] py-3 text-center'>
      <p class='text-sm md:text-base px-4'>We'd Love to Hear From You!</p>
    </div>

    <!-- Navigation -->
    <nav class='bg-[#F6F1ED] sticky top-0 z-50 pt-2'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2'>
        <div class='flex flex-col items-center space-y-4'>
          <!-- Logo -->
          <div class='flex items-center justify-center'>
            <a href='/' aria-label='BayanBites Home'>
              <img
                src='/logo.png'
                alt='BayanBites Logo'
                class='h-16 md:h-20 lg:h-24 w-auto cursor-pointer hover:opacity-90 transition-opacity'
              />
            </a>
          </div>

          <!-- Navigation Links -->
          <div class='flex items-center space-x-6'>
            <a
              href='/'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Home</a
            >
            <!-- Menu items hidden for now -->
            <!-- <a
              href='/cookies'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Cookies</a
            >
            <a
              href='/cinnamon'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Cinnamon Rolls</a
            >
            <a
              href='/cakes'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Cakes</a
            > -->
            <a
              href='/#our-story'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors'
              >Our Story</a
            >
            <a
              href='/contact'
              class='text-[#ab2a08] hover:text-[#F5A623] transition-colors font-semibold'
              >Contact</a
            >
          </div>
        </div>
      </div>
    </nav>

    <!-- Hero Image Section -->
    <section class='relative h-96 md:h-[250px] overflow-hidden'>
      <img
        src='https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d?w=1600&h=800&fit=crop'
        alt='Contact BayanBites'
        class='w-full h-full object-cover'
      />
      <div
        class='absolute inset-0 bg-black bg-opacity-30 flex items-center justify-center'
      >
        <div class='text-center text-white px-4'>
          <h1 class='text-5xl md:text-6xl font-bold mb-4 drop-shadow-lg'>
            Get In Touch
          </h1>
          <p class='text-xl md:text-2xl drop-shadow-lg'>
            We're here to help with your orders and questions
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Information Section -->
    <section class='py-8 bg-[#f5f1ed]'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
        <div class='text-center mb-12'>
          <h2 class='text-4xl text-[#ab2a08] mb-4'>Contact Us</h2>
          <p class='text-[#dc143c] max-w-2xl mx-auto'>
            Ready to place an order or have questions about our products? We'd
            love to hear from you!
          </p>
        </div>

        <!-- Contact Cards -->
        <div class='grid grid-cols-1 md:grid-cols-2 gap-8 mb-16'>
          <!-- Facebook Messenger Card -->
          <div
            class='bg-white rounded-lg shadow-lg p-8 hover:shadow-xl transition-shadow'
          >
            <div class='flex flex-col items-center text-center'>
              <div
                class='bg-[#ab2a08] text-white rounded-full w-20 h-20 flex items-center justify-center mb-6'
              >
                <svg class='w-10 h-10' fill='currentColor' viewBox='0 0 24 24'>
                  <path
                    d='M12 2C6.477 2 2 6.145 2 11.243c0 2.898 1.445 5.478 3.704 7.164V22l3.412-1.872c.91.252 1.876.386 2.884.386 5.523 0 10-4.145 10-9.243C22 6.145 17.523 2 12 2zm.993 12.464l-2.551-2.721-4.98 2.721 5.478-5.814 2.613 2.721 4.918-2.721-5.478 5.814z'
                  ></path>
                </svg>
              </div>
              <h3 class='text-2xl text-[#ab2a08] mb-4'>
                Message Us on Facebook
              </h3>
              <p class='text-[#dc143c] mb-6'>
                Send us a message on Facebook Messenger for the fastest
                response. We typically reply within a few hours during business
                hours.
              </p>
              <a
                href='https://www.facebook.com/profile.php?id=61581222617160'
                target='_blank'
                rel='noopener noreferrer'
                class='bg-[#ab2a08] text-white px-8 py-3 rounded-md hover:bg-[#8B0000] transition-colors inline-flex items-center'
              >
                <svg
                  class='w-5 h-5 mr-2'
                  fill='currentColor'
                  viewBox='0 0 24 24'
                >
                  <path
                    d='M12 2C6.477 2 2 6.145 2 11.243c0 2.898 1.445 5.478 3.704 7.164V22l3.412-1.872c.91.252 1.876.386 2.884.386 5.523 0 10-4.145 10-9.243C22 6.145 17.523 2 12 2zm.993 12.464l-2.551-2.721-4.98 2.721 5.478-5.814 2.613 2.721 4.918-2.721-5.478 5.814z'
                  ></path>
                </svg>
                Open Messenger
              </a>
            </div>
          </div>

          <!-- Phone Card -->
          <div
            class='bg-white rounded-lg shadow-lg p-8 hover:shadow-xl transition-shadow'
          >
            <div class='flex flex-col items-center text-center'>
              <div
                class='bg-[#ab2a08] text-white rounded-full w-20 h-20 flex items-center justify-center mb-6'
              >
                <svg
                  class='w-10 h-10'
                  fill='none'
                  stroke='currentColor'
                  viewBox='0 0 24 24'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'
                  ></path>
                </svg>
              </div>
              <h3 class='text-2xl text-[#ab2a08] mb-4'>Call or Text Us</h3>
              <p class='text-[#dc143c] mb-6'>
                Prefer to talk? Give us a call or send us a text message. We're
                available during business hours.
              </p>
              <a
                href='tel:02040548889'
                class='text-3xl text-[#ab2a08] font-semibold mb-4 hover:text-[#F5A623] transition-colors'
              >
                020 4054 8889
              </a>
              <div class='flex gap-4 mt-4'>
                <a
                  href='tel:02040548889'
                  class='bg-[#ab2a08] text-white px-6 py-2 rounded-md hover:bg-[#8B0000] transition-colors inline-flex items-center'
                >
                  <svg
                    class='w-5 h-5 mr-2'
                    fill='none'
                    stroke='currentColor'
                    viewBox='0 0 24 24'
                  >
                    <path
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      stroke-width='2'
                      d='M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'
                    ></path>
                  </svg>
                  Call Now
                </a>
                <a
                  href='sms:02040548889'
                  class='bg-[#F5A623] text-white px-6 py-2 rounded-md hover:bg-[#d89420] transition-colors inline-flex items-center'
                >
                  <svg
                    class='w-5 h-5 mr-2'
                    fill='none'
                    stroke='currentColor'
                    viewBox='0 0 24 24'
                  >
                    <path
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      stroke-width='2'
                      d='M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z'
                    ></path>
                  </svg>
                  Send SMS
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class='bg-[#ab2a08] text-white py-12'>
      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center'>
        <h3 class='text-2xl mb-4'>BayanBites</h3>
        <p class='text-[#f5f1ed] mb-6'>
          Freshly baked goods made with quality ingredients and thoughtful care.
        </p>
        <div class='border-t border-[#dc143c] pt-6 mt-6'>
          <p class='text-[#f5f1ed]'>
            &copy; 2026 BayanBites. All rights reserved.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
